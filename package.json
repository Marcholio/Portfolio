{
  "name": "portfolio",
  "version": "4.0.0",
  "repository": "https://github.com/Marcholio/Portfolio/",
  "homepage": "https://markustyrkko.fi",
  "license": "UNLICENSED",
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-lazyload": "3.2.1",
    "react-scroll": "1.9.3",
    "react-skeleton-css": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-lazyload": "3.2.3",
    "@types/react-scroll": "1.8.10",
    "eslint": "10.0.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-prettier": "5.5.5",
    "gh-pages": "6.3.0",
    "node-sass": "9.0.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build-app": "bun build-css && GENERATE_SOURCEMAP=false next build && cp CNAME build/CNAME && touch build/.nojekyll",
    "start": "bunx serve@latest ./build",
    "build-css": "node-sass ./src/styles -o ./src/styles",
    "watch-css": "bun build-css && node-sass ./src/styles -o ./src/styles --watch --recursive",
    "lint": "node_modules/.bin/eslint ./",
    "predeploy": "bun build-app",
    "deploy": "gh-pages -d build -t"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
